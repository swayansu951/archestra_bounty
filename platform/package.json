{
  "name": "archestra-platform",
  "version": "1.2.1",
  "description": "Enterprise MCP platform",
  "author": "Archestra",
  "engines": {
    "node": ">=18.0.0 <25.0.0"
  },
  "scripts": {
    "prepare": "cd .. && husky platform/.husky || true",
    "ci:check": "turbo check:ci",
    "commit:check": "turbo check:commit",
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "lint:fix:unsafe": "turbo lint:fix:unsafe",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "knip": "turbo knip",
    "test:e2e": "turbo test:e2e",
    "test:e2e:ui": "turbo test:e2e:ui",
    "check:ci": "turbo check:ci",
    "license-check": "tsx standalone-scripts/license-check.ts",
    "codegen": "CODEGEN=true turbo codegen && python3 dev/grafana/generate-pg-dashboard-variants.py",
    "db:generate": "turbo db:generate --ui=tui",
    "db:migrate": "turbo db:migrate",
    "db:push": "turbo db:push",
    "db:studio": "turbo db:studio",
    "db:seed:mock-data": "turbo db:seed:mock-data",
    "cleanup:dev:k8s": "kubectl delete namespace archestra-dev"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "tsx": "^4.21.0",
    "turbo": "^2.8.13",
    "typescript": "^5.9.2"
  },
  "pnpm": {
    "overrides": {
      "@fastify/reply-from": "12.5.0",
      "@hono/node-server": "1.19.11",
      "body-parser": "2.2.1",
      "dompurify": "3.3.3",
      "glob": "11.1.0",
      "esbuild": "0.27.0",
      "node-forge": "1.3.2",
      "mdast-util-to-hast": "13.2.1",
      "express": "5.2.0",
      "express-rate-limit": "8.3.1",
      "jws": "4.0.1",
      "qs": "6.14.2",
      "d3-path": "3.1.0",
      "hono": "4.12.9",
      "kysely": "0.28.14",
      "lodash": "4.17.23",
      "lodash-es": "4.17.23",
      "fast-xml-parser": "5.5.7",
      "@isaacs/brace-expansion": "5.0.1",
      "ajv": "8.18.0",
      "axios": ">=1.13.5",
      "minimatch": ">=10.2.3",
      "rollup": ">=4.59.0",
      "serialize-javascript": ">=7.0.3",
      "undici": "7.24.5"
    },
    "patchedDependencies": {
      "ai@6.0.90": "patches/ai@6.0.90.patch"
    }
  },
  "packageManager": "pnpm@10.33.0"
}
